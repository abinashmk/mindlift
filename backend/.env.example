# Copy to .env and fill in values before running locally.
DATABASE_URL=postgresql+asyncpg://mindlift:mindlift_secret@localhost:5432/mindlift_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ENVIRONMENT=development
DEBUG=false

# AI chat (get your key at https://console.anthropic.com)
ANTHROPIC_API_KEY=
